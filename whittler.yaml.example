# Whittler configuration example
# Copy to whittler.yaml and edit as needed.

# Path to the root of the git repository Whittler will manage.
repo_root: .

# Maximum number of beads (work items) to process concurrently.
max_lanes: 2

# How often (in seconds) to poll for new ready beads.
poll_interval: 5

# Maximum seconds a solver agent container may run before being killed.
agent_timeout: 900

# Number of times to retry a failed bead before marking it as permanently failed.
max_retries: 3

# Docker image to use when launching solver agent containers.
container_image: whittler-solver:latest

# Memory limit passed to the solver container (Docker --memory format, e.g. 4g, 512m).
container_memory: 4g

# Number of CPUs allocated to each solver container (Docker --cpus format).
container_cpu: 2

# Base directory under which per-bead git worktrees are created.
worktree_base: .worktrees

# Shell command to run after a bead is merged to validate the repository.
# Leave empty to skip post-merge validation.
validation_command: ""

# Path to the Whittler log file.
log_file: whittler.log

# Path to the JSON file used to persist orchestrator state across restarts.
state_file: .whittler-state.json

# Path to the lock file used to prevent multiple Whittler instances from running simultaneously.
lock_file: .whittler.lock
